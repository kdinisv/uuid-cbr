{
  "name": "uuid-cbr",
  "version": "0.1.2",
  "description": "Bank of Russia UID generator for Node.js based on UUID v1 with checksum",
  "keywords": [
    "uuid",
    "uid",
    "uuid-v1",
    "cbr",
    "bank-of-russia",
    "central-bank-russia",
    "bank-russia",
    "bank-rossii",
    "checksum"
  ],
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "README.md"
  ],
  "sideEffects": false,
  "author": "kdinisv",
  "homepage": "https://github.com/kdinisv/uuid-cbr#readme",
  "bugs": {
    "url": "https://github.com/kdinisv/uuid-cbr/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kdinisv/uuid-cbr"
  },
  "license": "MIT",
  "scripts": {
    "test": "node --test test.js",
    "compare:official": "node scripts/compare-official.js",
    "verify:publish": "npm test && npm run compare:official && npm pack --dry-run",
    "prepublishOnly": "npm run verify:publish"
  }
}
